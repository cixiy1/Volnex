# ============================================================
# Volnex .gitignore  (Flutter application)
# 说明：屏蔽编译产物、依赖缓存、IDE 配置与本地环境文件。
# 注意：本项目是「应用」而非「库」，pubspec.lock 需纳入版本控制，故不忽略。
# ============================================================

# ---------- Flutter / Dart 编译产物与缓存 ----------
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
coverage/

# ---------- iOS / Android 原生编译产物 ----------
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/key.properties
ios/Pods/
ios/.symlinks/
ios/build/
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
*.p12
*.mobileprovision

# ---------- 桌面/Web 平台编译产物 ----------
linux/flutter/ephemeral/
macos/Flutter/ephemeral/
windows/flutter/ephemeral/

# ---------- IDE / 编辑器配置 ----------
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ---------- 系统文件 ----------
.DS_Store
Thumbs.db

# ---------- 环境变量 ----------
.env
.env.local
.env.*.local

# ---------- 日志 ----------
*.log
